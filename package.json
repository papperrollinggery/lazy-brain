{
  "name": "lazybrain",
  "version": "1.4.5",
  "description": "Semantic skill router for AI coding agents — your second brain for capabilities",
  "type": "module",
  "bin": {
    "lazybrain": "./dist/bin/lazybrain.js",
    "lb": "./dist/bin/lazybrain.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README_CN.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "audit:public": "node scripts/audit-public.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude-code",
    "skill-router",
    "semantic-matching",
    "ai-agent",
    "knowledge-graph",
    "lazybrain"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "husky": "^9.1.7",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.1.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.60.1",
    "@rollup/rollup-darwin-x64": "^4.60.2",
    "@rollup/rollup-linux-x64-gnu": "^4.60.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/papperrollinggery/lazy-brain.git"
  }
}
